# Copie para .env e preencha. O .env é ignorado pelo Git.
OPENROUTER_API_KEY=

# Opcionais (valores padrão mostrados)
#AUDIOFY_TEXT_MODEL=google/gemini-2.5-pro
#AUDIOFY_AUDIT_MODEL=google/gemini-2.5-flash
#AUDIOFY_TTS_MODEL=google/gemini-3.1-flash-tts-preview

# Apresentadores: "nome:Voz[:tom]" separados por vírgula (1 ou mais).
# Vozes disponíveis: menu Catálogo TTS/vozes. Exemplos:
#AUDIOFY_PRESENTERS=apresentador_a:Kore:curioso, apresentador_b:Puck:didático
#AUDIOFY_PRESENTERS=narrador:Sulafat
#AUDIOFY_PRESENTERS=ana:Kore:animada, beto:Puck:cético, carla:Aoede:técnica

# Gemini TTS só aceita "pcm" (o pipeline embrulha em WAV); outros modelos podem aceitar mp3/wav
#AUDIOFY_TTS_FORMAT=pcm
#AUDIOFY_TTS_SAMPLE_RATE=24000
